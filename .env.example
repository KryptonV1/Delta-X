# ─────────────────────────────────────────────
#  DELTA X — Environment Configuration
# ─────────────────────────────────────────────

# Binance (public data — no key needed, but add for higher rate limits)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here   # can be a group/channel ID

# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=your_service_role_key_here

# Flask
PORT=5000
SECRET_KEY=change_this_to_a_random_string

# System
LOG_LEVEL=INFO        # DEBUG | INFO | WARNING | ERROR

# Telegram Admin (WAJIB — private chat dengan bot sahaja, bukan channel)
# Cara dapat ID: Hantar /start ke @userinfobot dalam Telegram
TELEGRAM_ADMIN_ID=your_telegram_user_id_here
